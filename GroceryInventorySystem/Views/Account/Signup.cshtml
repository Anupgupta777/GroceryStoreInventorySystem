@model GroceryInventorySystem.Models.SignupViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>

<head>

    <title>Sign Up</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

</head>

<body style="background:linear-gradient(135deg,#2196F3,#0D47A1);">

    <div class="container">

        <div class="row justify-content-center">

            <div class="col-md-5 mt-5">

                <div class="card shadow-lg border-0 rounded-4">

                    <div class="card-body p-4">

                        <h2 class="text-center text-primary mb-4">
                            Create Account
                        </h2>

                        <form>

                            <div class="mb-3">

                                <label>Full Name</label>

                                <input asp-for="FullName"
                                       class="form-control" />

                            </div>

                            <div class="mb-3">

                                <label>Email</label>

                                <input asp-for="Email"
                                       class="form-control" />

                            </div>

                            <div class="mb-3">

                                <label>Phone Number</label>

                                <input asp-for="PhoneNumber"
                                       class="form-control" />

                            </div>

                            <div class="mb-3">

                                <label>OTP</label>

                                <div class="input-group">

                                    <input asp-for="OTP"
                                           class="form-control" />

                                    <button type="button"
                                            class="btn btn-success">
                                        Verify OTP
                                    </button>

                                </div>

                            </div>

                            <div class="mb-3">

                                <label>Username</label>

                                <input asp-for="Username"
                                       class="form-control" />

                            </div>

                            <div class="mb-3">

                                <label>Password</label>

                                <input asp-for="Password"
                                       type="password"
                                       class="form-control" />

                            </div>

                            <button type="submit"
                                    class="btn btn-primary w-100">
                                Create Account
                            </button>

                        </form>

                        <div class="text-center mt-3">

                            <a asp-controller="Account"
                               asp-action="Login">
                                Back to Login
                            </a>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</body>
</html>