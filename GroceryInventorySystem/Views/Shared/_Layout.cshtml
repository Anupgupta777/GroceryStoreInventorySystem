<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Grocery Store</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body>

    <div class="layout-wrapper">

        <!-- Sidebar -->
        <div class="sidebar">

            <h4 class="logo">
                Grocery Store
            </h4>

            <div class="text-center mb-4">

                <img src="https://cdn-icons-png.flaticon.com/512/3135/3135715.png"
                     width="80"
                     class="rounded-circle border border-3 border-white" />

                <h6 class="text-white mt-2">
                    Admin User
                </h6>

                <small class="text-light">
                    System Administrator
                </small>

            </div>

            <a asp-controller="Dashboard" asp-action="Index">
                📊 Dashboard
            </a>

            <a asp-controller="Products" asp-action="Index">
                📦 Products
            </a>

            <a asp-controller="Categories" asp-action="Index">
                📁 Categories
            </a>

            <a asp-controller="Suppliers" asp-action="Index">
                🚚 Suppliers
            </a>

            <a asp-controller="Users" asp-action="Index">
                👤 Users
            </a>

            <a asp-controller="Sales" asp-action="Index">
                💰 Sales
            </a>

        </div>

        <!-- Main Content -->
        <div class="main-content">

            <div class="top-bar">

                <input type="text"
                       class="form-control search-box"
                       placeholder="Search..." />

                <div class="d-flex align-items-center gap-3">

                    <span class="fw-bold text-primary">
                        👤 Admin
                    </span>

                    <a asp-controller="Account"
                       asp-action="Logout"
                       class="btn btn-danger btn-sm">
                        🚪 Logout
                    </a>

                </div>

            </div>

            @RenderBody()

            <footer class="text-center text-muted mt-5">

                <hr />

                © 2026 Grocery Inventory System

            </footer>

        </div>

    </div>

</body>
</html>